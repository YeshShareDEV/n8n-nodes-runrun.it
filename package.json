{
  "name": "n8n-nodes-runrunit",
  "version": "0.3.38",
  "description": "n8n community nodes for Runrun.it (Runrunit) integrations",
  "license": "MIT",
  "homepage": "",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-node",
    "runrunit",
    "runrun",
    "runrun.it",
    "project-management"
  ],
  "author": {
    "name": "Marcos Campos",
    "email": "marcos@yesh.com.br"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YeshShareDEV/n8n-nodes-runrun.it.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "debug:env": "node -e \"console.log(process.env.PATH); const { execSync } = require('child_process'); try { console.log(execSync('command -v n8n-node').toString().trim()); } catch (e) { console.log('n8n-node: not found'); }\"",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist",
    "README.md",
    "nodes/**/*.svg",
    "nodes/**/*.png"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/RunrunitApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Runrunit/Runrunit.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "n8n-node-dev": "^1.121.16",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
