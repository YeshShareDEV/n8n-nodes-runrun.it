{
  "name": "n8n-nodes-runrunit",
  "version": "1.1.19",
  "description": "n8n community nodes for Runrun.it (Runrunit) integrations",
  "license": "MIT",
  "homepage": "https://github.com/YeshShareDEV/n8n-nodes-runrun.it",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-node",
    "runrunit",
    "runrun",
    "runrun.it",
    "project-management"
  ],
  "author": {
    "name": "Marcos Campos",
    "email": "marcos@yesh.com.br"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YeshShareDEV/n8n-nodes-runrun.it.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "postbuild": "node -e \"require('fs').copyFileSync('README.md', 'dist/README.md')\"",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist",
    "nodes/**/*.svg",
    "nodes/**/*.png"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/RunrunitApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Runrunit/Runrunit.node.js"
    ]
  },
  "devDependencies": {
    "n8n-workflow": "^1.0.0",
    "n8n-core": "^1.0.0",
    "n8n-node-dev": "^1.60.0",
    "typescript": "~5.4.5",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.10.0"
  }
}
